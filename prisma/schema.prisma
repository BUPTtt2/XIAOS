generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id          String   @id @default(cuid())
  name        String?
  email       String   @unique
  password    String?
  apiKey      String?
  scripts     Script[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Script {
  id          String   @id @default(cuid())
  title       String
  content     Json
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}
